{
  "installCommand": "cd vercel && npm ci",
  "buildCommand": "cd vercel && npm run build",
  "outputDirectory": "vercel/dist",
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Permissions-Policy",
          "value": "bluetooth=(self), local-network=(self), loopback-network=(self), local-network-access=(self)"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
